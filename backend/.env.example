# App
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
BACKEND_URL=http://localhost:3001
APP_SECRET=change_me_to_a_32_char_random_string_here

# Database (Supabase)
# Connection string: Settings → Database → Connection string → URI tab
DATABASE_URL=postgresql://postgres:your_db_password@db.your_project_ref.supabase.co:5432/postgres

# Project URL: Settings → API → Project URL
SUPABASE_URL=https://your_project_ref.supabase.co

# Secret key (server-side only — never expose to browser):
#   New projects (July 2025+): Settings → API → Secret keys → copy the sb_secret_... value
#   Older projects:            Settings → API → Project API keys → service_role → Reveal
SUPABASE_SERVICE_KEY=your_supabase_service_key
# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# HubSpot OAuth App
HUBSPOT_CLIENT_ID=your_hubspot_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
HUBSPOT_REDIRECT_URI=http://localhost:3001/api/oauth/hubspot/callback
HUBSPOT_WEBHOOK_SECRET=your_hubspot_webhook_secret

# Wix App
WIX_APP_ID=your_wix_app_id
WIX_APP_SECRET=your_wix_app_secret
WIX_WEBHOOK_SECRET=your_wix_webhook_secret

# Observability
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
